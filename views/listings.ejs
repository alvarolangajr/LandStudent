<!DOCTYPE html>
<html>
<head>
  <title>Listings</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <section class="section">
    <h2>All Listings</h2>

    <form action="/listings" method="GET" class="filter-bar">
      <input type="text" name="location" placeholder="Search by location">
      <input type="number" name="maxPrice" placeholder="Max price">
      <input type="text" name="type" placeholder="Type">
      <button type="submit">Filter</button>
    </form>

    <% if (listings.length === 0) { %>
      <p>No listings yet.</p>
    <% } %>

    <% listings.forEach(l => { %>
      <div class="card">
        <h3><%= l.title %></h3>
        <p><strong>Location:</strong> <%= l.location %></p>
        <p><strong>Price:</strong> €<%= l.price %></p>
        <p><strong>Type:</strong> <%= l.type %></p>
        <a href="/listings/<%= l._id %>">View Details</a>
      </div>
    <% }) %>
  </section>
</body>
</html>