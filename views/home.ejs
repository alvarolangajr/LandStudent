<!DOCTYPE html>
<html>
<head>
  <title>LandStudent</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<%- include('partials/navbar') %>

<section class="hero">
  <div class="hero-content">
    <h1>Find student housing with our help</h1>
    <p>Search rooms, apartments, and shared flats here with ease.</p>
    <a href="/listings" class="hero-btn">Browse Listings</a>
  </div>
</section>

<section class="section">
  <h2>Recent Listings</h2>

  <% if (listings.length === 0) { %>
    <p>No listings yet.</p>
  <% } %>

  <% listings.forEach(l => { %>
    <div class="card">
      <h3><%= l.title %></h3>
      <p><strong>Location:</strong> <%= l.location %></p>
      <p><strong>Price:</strong> €<%= l.price %></p>
      <a href="/listings/<%= l._id %>">View Details</a>
    </div>
  <% }) %>
</section>

</body>
</html>